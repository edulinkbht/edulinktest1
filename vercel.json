{
  "rewrites": [
    {
      "source": "/blog",
      "destination": "/blog"
    },
    {
      "source": "/",
      "destination": "/home"
    },
    {
      "source": "/feed/search/:query",
      "destination": "/home?q=:query&view=feed"
    },
    {
      "source": "/search/:query/:etab",
      "destination": "/home?q=:query&etab=:etab"
    },
    {
      "source": "/search/:query",
      "destination": "/home?q=:query&etab=explore"
    },
    {
      "source": "/:username/post/:num",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(WhatsApp|facebookexternalhit|Twitterbot|LinkedInBot|Discordbot).*"
        }
      ],
      "destination": "/api/share?username=:username&postNum=:num"
    },
    {
      "source": "/:username/post/:num",
      "destination": "/home"
    },
    {
      "source": "/feed",
      "destination": "/home"
    },
    {
      "source": "/search",
      "destination": "/home"
    },
    {
      "source": "/notifications",
      "destination": "/home"
    },
    {
      "source": "/profile/:username*",
      "destination": "/home"
    },
    {
      "source": "/saved",
      "destination": "/home?view=saved"
    },
    {
      "source": "/(.*)",
      "destination": "/404.html"
    }
  ]
}
